              <h3 className="text-2xl font-bold mb-2">Don't Leave Yet!</h3>
              <p className="text-gray-600 mb-4">Claim your 7-Day Free Trial before you go</p>
              <ul className="text-left mb-4 space-y-2">
                <li className="flex items-center gap-2"><Check size={16} className="text-green-500"/>Full audit of your current marketing</li>
                <li className="flex items-center gap-2"><Check size={16} className="text-green-500"/>Custom growth strategy session</li>
                <li className="flex items-center gap-2"><Check size={16} className="text-green-500"/>No commitment — cancel anytime</li>
