'use client';
import { useState, useEffect } from 'react';
import { motion } from 'framer-motion';
import { MessageCircle, Calendar, X, Globe, Users, Award, Check } from 'lucide-react';

export default function Home() {
  const [showPopup, setShowPopup] = useState(false);
  const [showForm, setShowForm] = useState(false);
  const [submitted, setSubmitted] = useState(false);

  useEffect(() => {
    const timer = setTimeout(() => setShowPopup(true), 7000);
    return () => clearTimeout(timer);
  }, []);

  const handleSubmit = (e: any) => {
    e.preventDefault();
    setSubmitted(true);
    setTimeout(() => { setShowForm(false); setSubmitted(false); }, 2500);
  };

  return (
    <main className="bg-[#0A1128] text-white font-sans">
      {/* NAVBAR */}
      <nav className="fixed top-0 w-full bg-[#0A1128]/80 backdrop-blur z-40 p-4 border-b border-[#1A2450]">
        <div className="max-w-7xl mx-auto flex justify-between items-center">
          <h1 className="text-2xl font-bold text-[#00C896]">HizTech</h1>
          <div className="hidden md:flex gap-4">
            <a href="https://wa.me/923034747338" target="_blank" className="bg-green-500 hover:bg-green-600 px-4 py-2 rounded-lg flex items-center gap-2 transition">
              <MessageCircle size={18}/> Chat on WhatsApp
            </a>
            <button onClick={() => setShowForm(true)} className="bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded-lg flex items-center gap-2 transition">
              <Calendar size={18}/> Book Free Consultation
            </button>
          </div>
        </div>
      </nav>

      {/* HERO */}
      <section className="pt-32 pb-20 text-center px-4">
        <motion.h1 initial={{opacity:0, y:20}} animate={{opacity:1, y:0}} className="text-5xl md:text-6xl font-bold mb-4">
          Your Global Growth Partner
        </motion.h1>
        <p className="text-xl text-gray-300 mb-6">
          Serving <span className="text-[#00C896] font-bold">UAE, USA, UK, KSA</span> & 40+ Countries
        </p>
        <div className="flex justify-center gap-8 mt-8">
          <div><Users className="mx-auto mb-2"/>250+ Happy Clients</div>
          <div><Globe className="mx-auto mb-2"/>40+ Countries</div>
          <div><Award className="mx-auto mb-2"/>7+ Years Experience</div>
        </div>
      </section>

      {/* SERVICES */}
      <section className="py-20 px-4 bg-[#121A3A]">
        <h2 className="text-3xl font-bold text-center mb-10">All Social Media Marketing Services</h2>
        <div className="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {['Google Ads','Meta Ads - FB & IG','TikTok Ads','LinkedIn Ads','SEO & Content','Web Design & Dev'].map(s => (
            <div key={s} className="bg-[#1A2450] p-6 rounded-xl hover:bg-[#242F6B] transition"><Check className="text-green-400 inline mr-2"/>{s}</div>
          ))}
        </div>
      </section>

      {/* TESTIMONIALS */}
      <section className="py-20 px-4">
        <h2 className="text-3xl font-bold text-center mb-10">Trusted by Clients Worldwide</h2>
        <div className="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
          <div className="bg-[#121A3A] p-6 rounded-xl">🇺🇸 <b>USA Client:</b> "HizTech 10x our ROI in 3 months. Best agency for Meta Ads."</div>
          <div className="bg-[#121A3A] p-6 rounded-xl">🇦🇪 <b>UAE Client:</b> "Leading digital agency in Dubai. They understand the UAE market perfectly."</div>
        </div>
      </section>

      {/* FOOTER */}
      <footer className="bg-[#121A3A] py-8 px-4 text-center border-t border-[#1A2450]">
        <p>Dubai, UAE | Serving Global Clients</p>
        <div className="flex justify-center gap-4 mt-4">
          <a href="#">Facebook</a><a href="#">Instagram</a><a href="#">LinkedIn</a><a href="#">TikTok</a>
        </div>
      </footer>

      {/* EXIT POPUP */}
      {showPopup && (
        <div className="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
          <div className="bg-white text-black rounded-2xl p-8 max-w-md w-full relative">
            <X onClick={() => setShowPopup(false)} className="absolute top-4 right-4 cursor-pointer"/>
            <div className="text-center">
