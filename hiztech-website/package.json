              <Calendar/> Book Free Consultation
            </button>
          </div>
        </div>
      )}

      {/* BOOKING FORM */}
      {showForm && (
        <div className="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
          <div className="bg-white text-black rounded-2xl p-8 max-w-md w-full relative">
            <X onClick={() => setShowForm(false)} className="absolute top-4 right-4 cursor-pointer"/>
            <h3 className="text-2xl font-bold mb-4">Book Free Consultation</h3>
            {submitted ? <p className="text-green-600 text-center font-bold">Submitted Successfully!</p> :
            <form onSubmit={handleSubmit} className="flex flex-col gap-3">
              <input placeholder="Full Name" className="border p-2 rounded" required/>
              <input placeholder="Email" type="email" className="border p-2 rounded" required/>
              <input placeholder="Phone" className="border p-2 rounded" required/>
              <select className="border p-2 rounded"><option>UAE</option><option>USA</option><option>UK</option><option>KSA</option><option>Other</option></select>
              <textarea placeholder="How can we help you?" className="border p-2 rounded h-20"></textarea>
              <button className="bg-blue-500 text-white py-2 rounded font-bold">Submit Request</button>
            </form>}
          </div>
        </div>
      )}
    </main>
  )
}
